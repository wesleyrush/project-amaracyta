[Unit]
Description=Jornada Akasha API (FastAPI)
After=network.target

[Service]
User=www-data
WorkingDirectory=/opt/jornada-akasha/backend
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=/opt/jornada-akasha/backend/.env
ExecStart=/opt/jornada-akasha/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
